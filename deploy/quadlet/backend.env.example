# Kopiera till /etc/kalle/backend.env på servern och fyll i värdena.
# Lägg ALDRIG den ifyllda filen i git. Sätt rättigheter: chmod 600.

NODE_ENV=production

# Krävs. Generera: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Krävs. Din separata Postgres.
DATABASE_URL=postgres://user:pwd@db-server:5432/kalle

# Valfritt – krävs bara om admins ska spara egna OpenAI-nycklar.
API_KEY_ENCRYPTION_KEY=

# Valfritt – delad OpenAI-nyckel för AI-uppdatering av svar.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5

# Kontaktformulär – SMTP för att skicka mejl. Utan SMTP_HOST loggas meddelandena
# bara (skickas ej). CONTACT_TO är mottagaradressen (default SMTP_FROM).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=465
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=no-reply@findersson.se
# CONTACT_TO=kontakt@findersson.se
