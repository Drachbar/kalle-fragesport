# Databasanslutning (Postgres, lokalt via podman/compose.yaml).
# Standardvärdena nedan matchar compose.yaml, så lokalt behövs ingen .env.
# I produktion: sätt DATABASE_URL till din hostade Postgres.

DATABASE_URL=postgres://kalle:kalle@localhost:5432/kalle

# Alternativ till DATABASE_URL (matchar compose.yaml):
# PGHOST=localhost
# PGPORT=5432
# PGUSER=kalle
# PGPASSWORD=kalle
# PGDATABASE=kalle

# Hemlighet för att signera sessions-cookien. Krävs i produktion.
# Generera t.ex. med: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=dev-only-insecure-secret

# Loggnivå: debug | info | warn | error | silent. Default "debug" (allt) i
# vanlig körning, "silent" under testkörning. Sätt till "info" för mindre brus.
# LOG_LEVEL=debug

# OpenAI – används för AI-uppdatering av svar (Responses API + web_search).
# Krävs först när en admin startar ett auto-uppdateringsjobb.
# Sätts denna används den (delad). Saknas den kan en admin istället ange en
# egen nyckel under Inställningar – då används adminens egna usage.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5

# Schemalagd auto-uppdatering. Av som standard. Sätts till "true" startas en
# schemaläggare som regelbundet kontrollerar de frågor vars kontrollintervall
# (update_interval_days per fråga) löpt ut. Kör du flera instanser/poddar tar
# bara en åt gången ett Postgres advisory lock, så jobbet körs aldrig dubbelt.
# Den schemalagda körningen har ingen inloggad admin och använder därför bara
# OPENAI_API_KEY ovan (admins egna nycklar gäller bara manuella körningar).
# AUTO_UPDATE_SCHEDULE_ENABLED=false
# Hur ofta schemaläggaren vaknar, i millisekunder (default 86400000 = 24h).
# AUTO_UPDATE_INTERVAL_MS=86400000

# Krypteringsnyckel för admins egna OpenAI-nycklar (AES-256-GCM).
# Krävs först när en admin sparar en egen nyckel under Inställningar.
# Valfri icke-tom hemlighet funkar (en 32-byte nyckel härleds via SHA-256),
# men använd hög entropi. Generera t.ex. med:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# API_KEY_ENCRYPTION_KEY=

# Kontaktformulär (skickar mejl via SMTP). Utan SMTP_HOST loggas meddelandena
# i stället för att skickas, så lokalt behövs inget. SMTP_PORT default 465 (TLS).
# CONTACT_TO är adressen meddelandena skickas till (faller tillbaka på SMTP_FROM).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=465
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=no-reply@findersson.se
# CONTACT_TO=kontakt@findersson.se
