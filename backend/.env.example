# Databasanslutning för lokal utveckling (matchar compose.yaml).
# Kopiera till .env och justera vid behov. Sätt antingen DATABASE_URL
# eller de enskilda PG*-variablerna.

# DATABASE_URL=postgres://kalle:kalle@localhost:5432/kalle

PGHOST=localhost
PGPORT=5432
PGUSER=kalle
PGPASSWORD=kalle
PGDATABASE=kalle
