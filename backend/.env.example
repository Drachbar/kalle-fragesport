# Databas.
#
# Som standard används PGlite (Postgres i WASM, in-process) – inget behöver
# installeras utöver Node, och data sparas i mappen ./pgdata.
#
# Vill du istället köra mot en riktig Postgres (t.ex. den i compose.yaml eller
# en hostad i produktion): sätt DATABASE_URL. Då används node-postgres (pg).
# Samma migreringar och SQL fungerar i båda lägena.

# DATABASE_URL=postgres://kalle:kalle@localhost:5432/kalle

# Mapp där PGlite sparar sin data (default ./pgdata). Används bara utan DATABASE_URL.
# PGLITE_DATA_DIR=./pgdata

# Anslutningsuppgifter för pg-läget (alternativ till DATABASE_URL).
# PGHOST=localhost
# PGPORT=5432
# PGUSER=kalle
# PGPASSWORD=kalle
# PGDATABASE=kalle

# Hemlighet för att signera sessions-cookien. Krävs i produktion.
# Generera t.ex. med: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=dev-only-insecure-secret
